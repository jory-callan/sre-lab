[mysqld]
# 设置3306端口
port=3306

#docker下不用设置，使用默认值即可，外部已经映射了默认的目录
# 自定义设置mysql的安装目录，即解压mysql压缩包的目录
#basedir==/data/env/mysql
# 自定义设置mysql数据库的数据存放目录
#datadir==/data/env/mysql/data

#sql_mode=STRICT_TRANS_TABLES,NO_AUTO_CREATE_USER,NO_ENGINE_SUBSTITUTION
sql_mode=

# 允许最大连接数
max_connections=20000
# 允许连接失败的次数，这是为了防止有人从该主机试图攻击数据库系统
max_connect_errors=1000

# 服务端使用的字符集默认为utf8mb4
character-set-server=utf8mb4
# 创建新表时将使用的默认存储引擎
default-storage-engine=INNODB
# 服务端的排序规则
# mysql-8.0 默认为这个  collation-server=utf8mb4_0900_ai_ci 也是推荐的排序
# collation-server=utf8mb4_general_ci # 对于 mysql5 就选这个

# mysql8.4 没了这个，默认使用“mysql_native_password”插件认证
# default_authentication_plugin=mysql_native_password

# mysql 8.0
# 设置时区
default-time-zone='+8:00'

# 设置 server_id ，同一个局域网中需要唯一
server_id=100
# 开启二进制日志功能
log-bin=mysql-bin
# 设置二进制日志使用内存大小（事务）
binlog_cache_size=1M
# mysql8.4 没了这个，设置使用二进制日志的格式（mixed ,  statement ,  row）
#binlog_format=mixed

## 下面的都是 mysql8 过期的配置
# 设置二进制日志过期清理时间。默认为0，表示不自动清理
#expire_logs_days=30
# 跳过主从复制中遇到的所有的错误或者指定类型的错误，避免slave端复制中断
# 如：1062 错误 是指一些主键重复，1032错误是因为主从数据库数据不一致
#slave_skip_errors=1062
# 当从库作为其他主库时，必须开启这个参数，该参数就是为了让从库从主库复制数据时可以写入到binlog日志
#log-slave-updates=1

[mysql]
# 设置mysql客户端默认字符集
default-character-set=utf8mb4

[client]
# 设置mysql客户端连接服务端时默认使用的端口和默认字符集
port=3306
default-character-set=utf8mb4